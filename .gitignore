# Local .terraform directory (contains provider binaries/plugins)
**/.terraform/*

# .tfstate files (only exist locally before migration or if you run local tests)
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Exclude all .tfvars files (these often contain passwords/secrets)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc